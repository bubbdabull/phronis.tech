# Public site URL (metadata, sitemap, robots)
NEXT_PUBLIC_SITE_URL=https://phronis.tech

# Privy — https://dashboard.privy.io → your app → App ID (client / browser)
NEXT_PUBLIC_PRIVY_APP_ID=

# Server (never expose to the client; used by API routes that verify users)
PRIVY_APP_SECRET=

# --- Privy dashboard checklist (enable to match app code) ---
# Auth: email only in app code (`loginMethods: ["email"]`). Disable Google/X/wallet login in the Privy dashboard.
# 1) Embedded wallets (Solana + Ethereum): https://docs.privy.io/wallets/overview/embedded
#    Turn on in Dashboard; app uses createOnLogin from env below. External extension wallets are disabled in code.
# 2) EVM smart wallets: configure chain(s), bundler, and paymaster in Dashboard. App wraps
#    SmartWalletsProvider so linking works when Dashboard has smart wallets enabled.
# 3) Earn / yield vault: https://docs.privy.io/wallets/actions/earn/setup — deploy fee wrapper,
#    copy vault_id for server calls; no vault env required for basic auth + wallets.

# Embedded wallet creation on login: all-users | users-without-wallets | off
# NEXT_PUBLIC_PRIVY_EMBEDDED_ETH_CREATE=all-users
# NEXT_PUBLIC_PRIVY_EMBEDDED_SOL_CREATE=all-users

# Optional: JSON object passed to SmartWalletsProvider as paymasterContext (non-secret policy
# IDs only; prefer Dashboard for sensitive paymaster config). Example: {"policyId":"..."}
# NEXT_PUBLIC_PRIVY_SMART_WALLET_PAYMASTER_CONTEXT_JSON=

# Supabase — URL is public. Server routes use the service_role JWT only (never prefix it with NEXT_PUBLIC_).
# Optional: new Supabase “publishable” key for browser clients (sb_publishable_…), if you add client-side Supabase later.
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Project Settings → API → service_role secret (long JWT starting with eyJ…, or sb_secret_… per your project).
# Wrong key or anon key here → “Invalid API key” from PostgREST.
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# PHR (DAO) SPL mint (public). Used for balances, buy flow, and DAO gate.
NEXT_PUBLIC_PHRONIS_DAO_TOKEN_MINT=

# USDC SPL mint (public). Defaults to mainnet USDC; set a devnet mint when NEXT_PUBLIC_SOLANA_CLUSTER=devnet.
# NEXT_PUBLIC_USDC_MINT=

# Optional: deployed Solana program id for the Phronis DAO Anchor program (see solana/phronis-dao/README.md).
# NEXT_PUBLIC_PHRONIS_DAO_PROGRAM_ID=

# DAO **security** model uses L1 / L2 / L3 for on-chain / off-chain / app layers (NOT the same as
# membership_tier L1–L3 on members). See docs/DAO_SECURITY_LAYERS_L1_L2_L3.md
# Member workspace (Welcome, APIs, Academy): same L1–L3 security model — docs/MEMBER_SECTION_SECURITY_L1_L2_L3.md

# Minimum PHR (human units, e.g. 1 = 1 token if mint has 0 decimals — adjust for your mint) to unlock /dao routes
NEXT_PUBLIC_DAO_MIN_PHR_BALANCE=0

# Set to true when DAO / membership block on /member should be visible (default: hidden).
# NEXT_PUBLIC_DAO_OPEN=true

# Solana RPC — use a server-only URL (e.g. Alchemy https://solana-mainnet.g.alchemy.com/v2/KEY).
# Never commit real keys. Prefer SOLANA_RPC_URL so the key is not bundled to the browser.
SOLANA_RPC_URL=
# NEXT_PUBLIC_SOLANA_RPC_URL=

# EVM RPC for Privy embedded / external Ethereum wallets (browser; use Alchemy domain allowlist).
# Optional if you configure RPC in the Privy dashboard instead.
# NEXT_PUBLIC_ALCHEMY_ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY

# mainnet | devnet — affects explorer links, Solana cluster hints, and Privy funding UI
# NEXT_PUBLIC_SOLANA_CLUSTER=devnet

# Optional: Privy JWT verification key (App settings → Basics) to avoid JWKS fetch on cold start
# PRIVY_JWT_VERIFICATION_KEY=
#
# If you enable "Return user data in an identity token" in the Privy dashboard, keep
# PRIVY_APP_SECRET aligned with NEXT_PUBLIC_PRIVY_APP_ID — sync routes verify the identity JWT server-side.

# Member Terminal (optional; keep server-only except documented NEXT_PUBLIC_*)
# HELIUS_API_KEY=
# BIRDEYE_API_KEY=
# DEXSCREENER_API_KEY=   # optional; public read endpoints used by /desk do not require a key today
# PAI_API_KEY=         # optional; preferred for AI desk (OpenAI-compatible bearer)
# PAI_BASE_URL=        # optional; OpenAI-compatible API base (default https://api.openai.com/v1)
# PAI_MODEL=           # optional; overrides AI_MODEL for desk when set
# OPENAI_API_KEY=
# OPENAI_API_BASE_URL=
# AI_API_KEY=          # optional alias for OPENAI_API_KEY (AI desk)
# AI_BASE_URL=         # optional alias for OPENAI_API_BASE_URL (OpenAI-compatible /v1)
# AI_MODEL=gpt-4o-mini

# Resend — member support requests from /member (server-only)
# RESEND_API_KEY=
# RESEND_FROM=Phronis <noreply@yourdomain.com>
# Inbox for manual onboarding / assisted funding requests (defaults to SITE contact email)
# RESEND_SUPPORT_TO=contact@phronis.tech

# Rate limiting: configure at your CDN / edge (placeholders only in app code)
